{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Snapmaker Studio",
  "version": "0.4.0-beta.18.1",
  "identifier": "com.snapmakerstudio.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      { "label": "main", "title": "Snapmaker Studio", "width": 820, "height": 640, "dragDropEnabled": true }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: asset: http://asset.localhost; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' ipc: http://ipc.localhost http://127.0.0.1:* http://localhost:*; font-src 'self' data:; object-src 'none'; base-uri 'self'; frame-src 'none'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": ["icons/icon.ico"],
    "externalBin": ["bin/snapstudio-api"],
    "publisher": "DeadlyVirusIn / Snapmaker Studio",
    "copyright": "Copyright (c) 2026 Snapmaker Studio contributors",
    "windows": {
      "nsis": { "installMode": "currentUser" },
      "webviewInstallMode": { "type": "downloadBootstrapper" }
    }
  }
}
