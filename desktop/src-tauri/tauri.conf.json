{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Snapmaker Studio",
  "version": "0.0.1",
  "identifier": "com.snapmakerstudio.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      { "label": "main", "title": "Snapmaker Studio", "width": 820, "height": 640, "dragDropEnabled": true }
    ],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico"]
  }
}
