{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Snapmaker Studio",
  "version": "0.4.0-beta.5",
  "identifier": "com.snapmakerstudio.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      { "label": "main", "title": "Snapmaker Studio", "width": 820, "height": 640, "dragDropEnabled": true }
    ],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": ["icons/icon.ico"],
    "externalBin": ["bin/snapstudio-api"],
    "publisher": "DeadlyVirusIn / Snapmaker Studio",
    "copyright": "Copyright (c) 2026 Snapmaker Studio contributors",
    "windows": {
      "nsis": { "installMode": "currentUser" },
      "webviewInstallMode": { "type": "downloadBootstrapper" }
    }
  }
}
