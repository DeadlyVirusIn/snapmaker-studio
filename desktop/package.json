    "release:windows": "npm run build:sidecar && tauri build"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1",
    "@tanstack/react-query": "^5",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2",
    "class-variance-authority": "^0.7",
    "clsx": "^2",
    "lucide-react": "^0.460",
    "react": "^18",
    "react-dom": "^18",
    "react-router-dom": "^6",
    "tailwind-merge": "^2",
    "zustand": "^5"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@vitejs/plugin-react": "^4",
    "autoprefixer": "^10",
    "postcss": "^8",
    "tailwindcss": "^3",
    "tailwindcss-animate": "^1",
    "typescript": "^5",
    "vite": "^5",
    "vitest": "^4.1.9"
  }
