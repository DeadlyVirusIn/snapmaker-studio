{
  "name": "snapmaker-studio-desktop",
  "private": true,
  "version": "0.4.0-beta.20.2",
  "description": "Snapmaker Studio — the local-first workflow platform for modern 3D printing. Understand any design, check if it will print, get it ready, and monitor your Snapmaker U1.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
